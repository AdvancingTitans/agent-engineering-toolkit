{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://advancingtitans.github.io/aet/schemas/gate-plan-v2.schema.json",
  "title": "AET Gate Plan v2",
  "type": "object",
  "required": ["schema_version", "applicability", "risk_class", "claims", "candidate", "runner", "suite_objectives", "suite_designs", "suite_bindings", "scorer_sha256", "decision", "coverage", "history"],
  "properties": {
    "schema_version": {"const": "gate-plan/v2"},
    "plan_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "applicability": {"enum": ["NOT_APPLICABLE", "PRELIMINARY", "REQUIRED"]},
    "risk_class": {"enum": ["R0", "R1", "R2", "R3", "R4"]},
    "claims": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "candidate": {"type": "object"},
    "runner": {"type": "object"},
    "suite_objectives": {"type": "object", "minProperties": 2},
    "suite_designs": {"type": "object", "minProperties": 2},
    "suite_bindings": {"type": "object", "minProperties": 2},
    "scorer_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "decision": {"type": "object"},
    "coverage": {"type": "object"},
    "history": {"type": "object"}
  },
  "additionalProperties": false
}
