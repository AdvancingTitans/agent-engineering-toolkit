%% AET v1.9 可编辑架构源。使用 Mermaid CLI 渲染。
%% 颜色遵循 Hermes architecture-diagram 语义色板。
%%{init: {"theme":"base","themeVariables":{"background":"#020617","primaryTextColor":"#f8fafc","lineColor":"#64748b","edgeLabelBackground":"#0f172a","fontFamily":"JetBrains Mono, monospace"},"themeCSS":".edgeLabel,.edgeLabel p { color:#cbd5e1 !important; background-color:#0f172a !important; }"}}%%
flowchart TB
  EXEC["外部 Agent 执行<br/>Codex · Claude Code · 其他宿主"]

  subgraph AET["AET · evidence-driven Agent 工程质量与控制层"]
    direction LR
    EVID["Evidence Plane<br/>audit · review · trace<br/>context · decision · run · evolve"]
    QUAL["确定性 Quality<br/>diagnose：显式映射<br/>promote：validation-only Task v2"]
    LEARN["受限 Learning / Evolution<br/>Evidence Only · 目标 Adapter<br/>replay · 指标向量 Gate · stage"]
    HUMAN["人工采用边界<br/>审阅 · adopt --yes<br/>Decision Ledger"]
    EVID -->|"结构化证据<br/>FAIL · UNKNOWN · 哈希"| QUAL
    QUAL -->|"已确认回归输入"| LEARN
    LEARN -->|"满足门禁的 Candidate<br/>不会自动采用"| HUMAN
  end

  EXEC -->|"命令 · Diff · Artifact · Event"| EVID
  HUMAN -. "批准的受限资产" .-> EXEC

  PRIVATE["私有 Rollout 边界<br/>原始 stdout/stderr · transcript · 工作区副本<br/>显式环境变量名 allowlist"]
  TASK["Task v2 + 真实运行统计<br/>工具顺序/参数 · proof/artifact · 预算<br/>any/all · Wilson 95% · 配对 McNemar"]
  RELEASE["Commit-bound 真实宿主发布门禁<br/>手动 Producer · 6 次配对 Codex rollout<br/>在 Tag 重构并校验"]
  NONGOAL["明确非目标<br/>通用 Benchmark · LLM Judge 中心 · 语义 RCA/Graph<br/>聚类 · 自动修复/发布 · 工单/业务看板"]

  EXEC -. "私有宿主材料" .-> PRIVATE
  PRIVATE -->|"仅 Evidence Only 评分<br/>现象 · 哈希"| EVID
  TASK --> LEARN
  LEARN --> RELEASE
  NONGOAL -. "不在 AET 范围" .- AET

  classDef external fill:#1e293b,stroke:#94a3b8,color:#f8fafc,stroke-width:2px;
  classDef evidence fill:#083344,stroke:#22d3ee,color:#f8fafc,stroke-width:2px;
  classDef quality fill:#064e3b,stroke:#34d399,color:#f8fafc,stroke-width:2px;
  classDef learn fill:#4c1d95,stroke:#a78bfa,color:#f8fafc,stroke-width:2px;
  classDef human fill:#881337,stroke:#fb7185,color:#f8fafc,stroke-width:2px;
  classDef release fill:#78350f,stroke:#fbbf24,color:#f8fafc,stroke-width:2px;
  class EXEC,PRIVATE,NONGOAL external;
  class EVID evidence;
  class QUAL,TASK quality;
  class LEARN learn;
  class HUMAN human;
  class RELEASE release;
  style AET fill:#020617,stroke:#64748b,stroke-width:2px,stroke-dasharray:8 4,color:#f8fafc
  linkStyle default stroke:#64748b,stroke-width:2px,color:#cbd5e1
