flowchart TB
  EXEC["External Agent execution<br/>Codex · Claude Code · other hosts"]

  subgraph AET["AET · evidence-driven Agent engineering quality & control layer"]
    direction LR
    EVID["Evidence Plane<br/>audit · review · trace<br/>context · decision · run · evolve"]
    QUAL["Deterministic Quality<br/>diagnose: explicit mapping<br/>promote: validation-only Task v2"]
    LEARN["Bounded Learning / Evolution<br/>Evidence Only · target adapters<br/>replay · metric-vector Gate · stage"]
    HUMAN["Human adoption boundary<br/>review · adopt --yes<br/>Decision Ledger"]
    EVID -->|"structured evidence<br/>FAIL · UNKNOWN · hashes"| QUAL
    QUAL -->|"confirmed regression input"| LEARN
    LEARN -->|"qualifying candidate<br/>never automatic"| HUMAN
  end

  EXEC -->|"commands · diffs · artifacts · events"| EVID
  HUMAN -. "approved bounded asset" .-> EXEC

  PRIVATE["Private rollout boundary<br/>raw stdout/stderr · transcripts · workspace copies<br/>explicit env-name allowlist"]
  TASK["Task v2 + observed statistics<br/>tool order/args · proof/artifact · budgets<br/>any/all · Wilson 95% · paired McNemar"]
  RELEASE["Commit-bound real-host release gate<br/>manual producer · 6 paired Codex rollouts<br/>reconstruct and verify at tag"]
  NONGOAL["Deliberate non-goals<br/>general benchmark · LLM-Judge center · semantic RCA/Graph<br/>clustering · auto-fix/release · tickets/business dashboards"]

  EXEC -. "private host material" .-> PRIVATE
  PRIVATE -->|"Evidence Only scores<br/>phenomena · hashes"| EVID
  TASK --> LEARN
  LEARN --> RELEASE
  NONGOAL -. "outside AET scope" .- AET

  classDef external fill:#1e293b,stroke:#94a3b8,color:#f8fafc,stroke-width:2px;
  classDef evidence fill:#083344,stroke:#22d3ee,color:#f8fafc,stroke-width:2px;
  classDef quality fill:#064e3b,stroke:#34d399,color:#f8fafc,stroke-width:2px;
  classDef learn fill:#4c1d95,stroke:#a78bfa,color:#f8fafc,stroke-width:2px;
  classDef human fill:#881337,stroke:#fb7185,color:#f8fafc,stroke-width:2px;
  classDef release fill:#78350f,stroke:#fbbf24,color:#f8fafc,stroke-width:2px;
  class EXEC,PRIVATE,NONGOAL external;
  class EVID evidence;
  class QUAL,TASK quality;
  class LEARN learn;
  class HUMAN human;
  class RELEASE release;
  style AET fill:#020617,stroke:#64748b,stroke-width:2px,stroke-dasharray:8 4,color:#f8fafc
