{
  "intent": "Release AET v1.0: configurable Evidence IR, proof-bound execution records, Repo Archaeologist, static review artifacts, and GitHub-ready delivery.",
  "changed_path_budget": 45,
  "allowed_paths": [
    "aet.intent.json",
    ".gitignore",
    "PROJECT_MEMORY.md",
    "README.md",
    "CHANGELOG.md",
    "aet.toml",
    "pyproject.toml",
    "uv.lock",
    "src/aet/**",
    "tests/**",
    "skills/agent-engineering-toolkit/**",
    "docs/**",
    "schemas/**",
    "examples/**",
    ".github/**"
  ],
  "required_proofs": [
    {
      "id": "unit-tests",
      "command": "uv run --no-editable --reinstall-package agent-engineering-toolkit python -m unittest discover -s tests -v",
      "evidence": [
        "tests/test_audit.py"
      ]
    },
    {
      "id": "wheel-smoke-test",
      "command": "uv build && uv run --isolated --with dist/agent_engineering_toolkit-1.0.0-py3-none-any.whl aet --version",
      "evidence": [
        "pyproject.toml",
        "src/aet/evidence.py",
        "pyproject.toml"
      ]
    }
  ]
}
