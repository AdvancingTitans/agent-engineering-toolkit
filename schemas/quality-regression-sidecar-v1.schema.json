{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://advancingtitans.github.io/aet/schemas/quality-regression-sidecar-v1.schema.json",
  "title": "AET Quality Regression Sidecar v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["canonical_sha256", "phenomenon_code", "status", "candidate_repair_surface", "owner", "action", "confidence", "review_route", "diagnosis_evidence_refs", "mapping_version", "mapping_sha256", "representative_evidence", "first_seen", "last_seen", "support", "source_badcase_ids", "target_partition", "adoption", "writes_formal_eval"],
  "properties": {
    "canonical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "phenomenon_code": {"type": "string", "minLength": 1},
    "status": {"enum": ["FAIL", "UNKNOWN"]},
    "candidate_repair_surface": {"type": "string", "minLength": 1},
    "owner": {"type": "string", "minLength": 1},
    "action": {"type": "string", "minLength": 1},
    "confidence": {"enum": ["HIGH", "MEDIUM", "LOW"]},
    "review_route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "reasons"],
      "properties": {
        "required": {"type": "boolean"},
        "reasons": {"type": "array", "uniqueItems": true, "items": {"enum": ["HIGH_RISK", "LOW_CONFIDENCE", "RULE_CONFLICT", "NEW_SCHEMA"]}}
      }
    },
    "diagnosis_evidence_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "mapping_version": {"const": "quality-mapping/v1"},
    "mapping_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "representative_evidence": {"type": "array", "minItems": 1, "maxItems": 5, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "first_seen": {"type": "string", "format": "date-time"},
    "last_seen": {"type": "string", "format": "date-time"},
    "support": {"type": "integer", "minimum": 1},
    "source_badcase_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "target_partition": {"const": "validation"},
    "adoption": {"const": "human_review_required"},
    "writes_formal_eval": {"const": false}
  }
}
