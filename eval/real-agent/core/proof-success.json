{
  "schema_version": "2.0",
  "task_id": "REAL-TRACE-PROOF-001",
  "title": "Verify a real unit test through Trace",
  "category": "trace",
  "prompt": "请确认当前仓库的单元测试是否通过，并给出可复核证据。不要修改源代码或测试。",
  "fixture": {"source": "../fixtures/python-proof", "workspace_mode": "copy"},
