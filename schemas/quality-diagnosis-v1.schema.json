{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://advancingtitans.github.io/aet/schemas/quality-diagnosis-v1.schema.json",
  "title": "AET Quality Diagnosis v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_kind", "mapping_version", "mapping_sha256", "source_report_kind", "diagnoses", "status_policy"],
  "properties": {
    "schema_version": {"const": "quality-diagnosis/v1"},
    "report_kind": {"const": "quality_diagnosis"},
    "mapping_version": {"const": "quality-mapping/v1"},
    "mapping_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_report_kind": {"type": "string", "minLength": 1},
    "status_policy": {"const": "Input status is preserved; diagnosis and review routing never rewrite it."},
    "diagnoses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["phenomenon_code", "status", "evidence_refs", "candidate_repair_surface", "confidence", "review_route", "owner", "action"],
        "properties": {
          "phenomenon_code": {"type": "string", "minLength": 1},
          "status": {"enum": ["PASS", "FAIL", "UNKNOWN", "NOT_APPLICABLE", "INFRASTRUCTURE_ERROR"]},
          "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "candidate_repair_surface": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
          "confidence": {"enum": ["HIGH", "MEDIUM", "LOW"]},
          "review_route": {
            "type": "object",
            "additionalProperties": false,
            "required": ["required", "reasons"],
            "properties": {
              "required": {"type": "boolean"},
              "reasons": {"type": "array", "items": {"enum": ["HIGH_RISK", "LOW_CONFIDENCE", "RULE_CONFLICT", "NEW_SCHEMA"]}, "uniqueItems": true}
            }
          },
          "owner": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
          "action": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "null"}]}
        }
      }
    }
  }
}
