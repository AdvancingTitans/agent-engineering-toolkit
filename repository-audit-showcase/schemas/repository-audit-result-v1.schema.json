{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AdvancingTitans/agent-engineering-toolkit/blob/main/repository-audit-showcase/schemas/repository-audit-result-v1.schema.json",
  "title": "AET Repository Audit Result v1",
  "type": "object",
  "required": [
    "schema_version",
    "audit_version",
    "generated_at",
    "repository",
    "scope",
    "runtime",
    "llm",
    "review",
    "disclaimer",
    "report_kind",
    "summary",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "repository-audit-result/v1"
    },
    "audit_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "repository": {
      "$ref": "#/$defs/repository"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "runtime": {
      "$ref": "#/$defs/runtime"
    },
    "llm": {
      "$ref": "#/$defs/llm"
    },
    "review": {
      "$ref": "#/$defs/review"
    },
    "disclaimer": {
      "type": "string",
      "minLength": 1
    },
    "report_kind": {
      "const": "repository_audit"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "repository": {
      "type": "object",
      "required": [
        "case_id",
        "name",
        "url",
        "branch",
        "commit",
        "license"
      ],
      "properties": {
        "case_id": {
          "enum": [
            "swe-agent",
            "google-adk",
            "openhands"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "pattern": "^https://github\\.com/[^/]+/[^/]+/?$"
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "license": {
          "type": "object",
          "required": [
            "spdx",
            "path",
            "blob_sha"
          ],
          "properties": {
            "spdx": {
              "type": "string",
              "minLength": 1
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "blob_sha": {
              "type": "string",
              "pattern": "^[0-9a-f]{40}$"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": [
        "include",
        "exclude",
        "files_collected",
        "files_skipped"
      ],
      "properties": {
        "include": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "files_collected": {
          "type": "integer",
          "minimum": 0
        },
        "files_skipped": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "path",
              "reason"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "enum": [
                  "symbolic_link",
                  "size_limit",
                  "not_utf8"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "required": [
        "total_seconds",
        "max_seconds",
        "within_budget",
        "excludes"
      ],
      "properties": {
        "total_seconds": {
          "type": "number",
          "minimum": 0,
          "maximum": 900
        },
        "max_seconds": {
          "const": 900
        },
        "within_budget": {
          "const": true
        },
        "excludes": {
          "const": [
            "clone",
            "dependency_install",
            "llm_network",
            "manual_review"
          ]
        }
      },
      "additionalProperties": false
    },
    "llm": {
      "type": "object",
      "required": [
        "status",
        "model_name",
        "token_usage",
        "execution_time_seconds",
        "affects_findings"
      ],
      "properties": {
        "status": {
          "enum": [
            "PASS",
            "FAIL",
            "UNKNOWN",
            "NOT_APPLICABLE"
          ]
        },
        "model_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "token_usage": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "execution_time_seconds": {
          "type": "number",
          "minimum": 0
        },
        "affects_findings": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "review": {
      "type": "object",
      "required": [
        "status",
        "required_before_publication"
      ],
      "properties": {
        "status": {
          "enum": [
            "PENDING",
            "APPROVED",
            "REJECTED"
          ]
        },
        "required_before_publication": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "PASS",
        "FAIL",
        "UNKNOWN",
        "NOT_APPLICABLE"
      ],
      "properties": {
        "PASS": {
          "type": "integer",
          "minimum": 0
        },
        "FAIL": {
          "type": "integer",
          "minimum": 0
        },
        "UNKNOWN": {
          "type": "integer",
          "minimum": 0
        },
        "NOT_APPLICABLE": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "finding": {
      "type": "object",
      "required": [
        "id",
        "title",
        "status",
        "severity",
        "evidence",
        "impact",
        "recommendation",
        "rule_version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^AET-REPO-[0-9]{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "PASS",
            "FAIL",
            "UNKNOWN",
            "NOT_APPLICABLE"
          ]
        },
        "severity": {
          "enum": [
            "ERROR",
            "WARN",
            "INFO"
          ]
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "impact": {
          "type": "object",
          "required": [
            "level",
            "description"
          ],
          "properties": {
            "level": {
              "enum": [
                "high",
                "medium",
                "low"
              ]
            },
            "description": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "recommendation": {
          "type": "string",
          "minLength": 1
        },
        "rule_version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": [
        "path",
        "line",
        "detail"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
